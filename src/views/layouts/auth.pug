doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title ? title + ' - ' : ''}#{appName}
    link(rel="stylesheet", href="/css/app.css")
  body
    main.auth-shell
      section.auth-panel
        .auth-brand
          p.eyebrow Sistem Aset Lab
          h1= appName
        include ../partials/flash
        block content
