extends ../layouts/main

block content
  section.section-header
    div
      p.eyebrow Stock In Receiving
      h2= record.item_name
      p Jumlah diterima #{record.received_quantity}
    a.button.button-secondary(href="/receiving") Kembali

  section.content-panel
    form.form-grid(action=`/consumables/receiving/${record.id}/stock-in`, method="POST", novalidate)
      .form-group
        label(for="name") Nama BHP
        input#name(type="text", name="name", value=formData.name, required)
        if errors.name
          p.field-error= errors.name
      .form-group
        label(for="specification") Spesifikasi
        textarea#specification(name="specification", rows="3")= formData.specification
        if errors.specification
          p.field-error= errors.specification
      .form-group
        label(for="unit") Satuan
        input#unit(type="text", name="unit", value=formData.unit, required)
        if errors.unit
          p.field-error= errors.unit
      .form-group
        label(for="minimumStock") Stok Minimum
        input#minimumStock(type="number", name="minimumStock", value=formData.minimumStock, min="0", required)
        if errors.minimumStock
          p.field-error= errors.minimumStock
      .form-group
        label(for="roomId") Ruangan
        select#roomId(name="roomId")
          option(value="") Tidak ditentukan
          each room in rooms
            option(value=room.id, selected=String(formData.roomId) === String(room.id)) #{room.code} - #{room.name}
        if errors.roomId
          p.field-error= errors.roomId
      .form-group
        label(for="note") Catatan
        textarea#note(name="note", rows="3")= formData.note
        if errors.note
          p.field-error= errors.note
      .form-actions
        button.button(type="submit") Masukkan ke Stok BHP
